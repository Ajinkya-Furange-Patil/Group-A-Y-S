<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Security and Compliance Analysis Dashboard for Remote GitHub Repositories - AI Discovery Scanner" />
  <title>AI Repository Scan Dashboard — Telemetry Report</title>
  
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700;900&display=swap');

    /* ═══════════════ GLOBAL DESIGN TOKENS ═══════════════ */
    :root {
      --bg: #0a0a0b;
      --bg-subtle: #111113;
      --bg-panel: rgba(21, 21, 23, 0.7);
      --bg-hover: rgba(211, 13, 48, 0.08);
      --text-primary: #f0f0f0;
      --text-secondary: #8a8f98;
      --text-muted: #5a5f68;
      --red: #d30d30;
      --red-glow: rgba(211, 13, 48, 0.25);
      --red-border: rgba(211, 13, 48, 0.35);
      --border: rgba(255, 255, 255, 0.08);
      --border-strong: rgba(255, 255, 255, 0.15);
      --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.5);
      
      --font-mono: 'Share Tech Mono', 'Courier New', monospace;
      --font-sans: 'Rajdhani', 'Inter', sans-serif;
      --font-body: 'Inter', sans-serif;
      
      --color-secure: #00ffcc;
      --color-warning: #ffd200;
      --color-critical: #d30d30;
      --color-info: #00e5ff;
      
      --transition-fast: 150ms;
      --transition-normal: 250ms;
    }

    body.light-theme {
      --bg: #f5f5f7;
      --bg-subtle: #ffffff;
      --bg-panel: rgba(255, 255, 255, 0.85);
      --bg-hover: rgba(211, 13, 48, 0.03);
      --text-primary: #0f1419;
      --text-secondary: #536471;
      --text-muted: #8899a6;
      --red-glow: rgba(211, 13, 48, 0.08);
      --red-border: rgba(211, 13, 48, 0.18);
      --border: rgba(0, 0, 0, 0.08);
      --border-strong: rgba(0, 0, 0, 0.15);
      --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.06);
    }

    /* ═══════════════ GLOBAL RESET ═══════════════ */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: var(--bg);
      color: var(--text-primary);
      font-family: var(--font-body);
      min-height: 100vh;
      line-height: 1.5;
      padding: 24px;
      transition: background-color var(--transition-normal), color var(--transition-normal);
      overflow-x: hidden;
    }

    /* ═══════════════ DECORATIVE SCROLLBAR ═══════════════ */
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--red-border); border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--red); }

    /* ═══════════════ LAYOUT WRAPPER ═══════════════ */
    .container {
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 24px;
      animation: fadeIn 0.6s ease-out;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ═══════════════ PREMIUM GLASS PANEL ═══════════════ */
    .hud-panel {
      position: relative;
      background: var(--bg-panel);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--border);
      box-shadow: var(--shadow-lg);
      padding: 24px;
      border-radius: 8px;
      transition: border-color var(--transition-normal), background-color var(--transition-normal);
    }

    .hud-panel::before {
      content: '';
      position: absolute;
      top: 4px; left: 4px; right: 4px; bottom: 4px;
      border: 1px dashed rgba(211, 13, 48, 0.05);
      pointer-events: none;
      border-radius: 6px;
    }

    .hud-corner {
      position: absolute;
      width: 10px;
      height: 10px;
      border-color: var(--red);
      border-style: solid;
      pointer-events: none;
    }
    .c-tl { top: -1px; left: -1px; border-width: 2px 0 0 2px; }
    .c-tr { top: -1px; right: -1px; border-width: 2px 2px 0 0; }
    .c-bl { bottom: -1px; left: -1px; border-width: 0 0 2px 2px; }
    .c-br { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; }

    /* ═══════════════ HEADER SECTION ═══════════════ */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 20px;
      border-bottom: 2px solid var(--red);
      padding-bottom: 20px;
    }
    
    .header-left {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .logo-container {
      width: 50px;
      height: 50px;
      background: rgba(211, 13, 48, 0.1);
      border: 2px solid var(--red);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      border-radius: 4px;
      box-shadow: 0 0 10px var(--red-glow);
    }

    .title-area h1 {
      font-family: var(--font-sans);
      font-size: 2rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1px;
      line-height: 1.1;
    }

    .title-area h1 span {
      color: var(--red);
      text-shadow: 0 0 8px var(--red-glow);
    }

    .repo-link {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      color: var(--text-secondary);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 6px;
      margin-top: 4px;
      word-break: break-all;
    }
    .repo-link:hover {
      color: var(--red);
      text-decoration: underline;
    }

    .header-right {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 8px;
    }

    .theme-toggle-btn {
      background: transparent;
      border: 1px solid var(--border-strong);
      color: var(--text-primary);
      padding: 6px 12px;
      cursor: pointer;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      transition: background var(--transition-fast);
    }
    .theme-toggle-btn:hover {
      background: var(--bg-hover);
      border-color: var(--red);
    }

    .timestamp {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    /* ═══════════════ TOP SUMMARY BAR ═══════════════ */
    .summary-grid {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 24px;
    }

    @media (max-width: 900px) {
      .summary-grid {
        grid-template-columns: 1fr;
      }
    }

    /* Radial Score Dial */
    .dial-wrapper {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 16px;
    }

    .dial-svg-container {
      position: relative;
      width: 160px;
      height: 160px;
    }

    .dial-svg {
      transform: rotate(-90deg);
      width: 100%;
      height: 100%;
    }

    .dial-track {
      fill: none;
      stroke: rgba(255, 255, 255, 0.05);
      stroke-width: 10;
    }

    .dial-progress {
      fill: none;
      stroke-width: 10;
      stroke-linecap: round;
      transition: stroke-dashoffset 1.5s ease-in-out;
    }

    .dial-text {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      text-align: center;
    }

    .dial-number {
      font-family: var(--font-mono);
      font-size: 2.2rem;
      font-weight: 700;
      line-height: 1;
    }

    .dial-label {
      font-size: 0.65rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-top: 2px;
    }

    .confidence-badge {
      font-family: var(--font-mono);
      font-size: 0.95rem;
      font-weight: bold;
      text-transform: uppercase;
      margin-top: 10px;
      padding: 3px 12px;
      border-radius: 20px;
      border: 1px solid transparent;
    }

    .conf-high { color: var(--color-secure); background: rgba(0, 255, 204, 0.1); border-color: var(--color-secure); }
    .conf-med { color: var(--color-warning); background: rgba(255, 210, 0, 0.1); border-color: var(--color-warning); }
    .conf-low { color: var(--color-critical); background: rgba(211, 13, 48, 0.1); border-color: var(--color-critical); }

    /* HUD Summary Cards */
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
    }

    .hud-card {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--border);
      padding: 20px;
      border-radius: 4px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      overflow: hidden;
      transition: border-color var(--transition-fast), transform var(--transition-fast);
    }
    .hud-card:hover {
      border-color: var(--red);
      transform: translateY(-2px);
    }
    .hud-card::after {
      content: '';
      position: absolute;
      top: 0; left: 0; width: 100%; height: 2px;
      background: var(--border);
    }
    .hud-card:hover::after {
      background: var(--red);
    }

    .card-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-secondary);
      font-weight: 600;
    }

    .card-value {
      font-family: var(--font-mono);
      font-size: 2.2rem;
      font-weight: 700;
      margin: 10px 0;
      line-height: 1;
    }

    .card-desc {
      font-size: 0.7rem;
      color: var(--text-muted);
      text-transform: uppercase;
    }

    /* ═══════════════ NAVIGATION TABS ═══════════════ */
    .tab-bar {
      display: flex;
      gap: 8px;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--border);
      padding: 6px;
      border-radius: 4px;
    }

    .tab-btn {
      flex: 1;
      background: transparent;
      border: none;
      color: var(--text-secondary);
      font-family: var(--font-sans);
      font-size: 0.95rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      padding: 10px;
      cursor: pointer;
      border-radius: 3px;
      transition: all var(--transition-fast) ease;
    }

    .tab-btn:hover {
      color: var(--text-primary);
      background: rgba(255, 255, 255, 0.03);
    }

    .tab-btn.active {
      color: #ffffff;
      background: var(--red);
      box-shadow: 0 2px 10px var(--red-glow);
    }

    /* ═══════════════ MAIN CONTENTS ═══════════════ */
    .tab-content {
      display: none;
      animation: fadeIn 0.4s ease-out;
    }

    .tab-content.active {
      display: block;
    }

    .main-grid {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 24px;
    }

    @media (max-width: 1000px) {
      .main-grid {
        grid-template-columns: 1fr;
      }
    }

    /* Overview Content Styles */
    .overview-section-title {
      font-family: var(--font-sans);
      font-size: 1.25rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--red);
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .overview-section-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: rgba(211, 13, 48, 0.2);
    }

    .chips-container {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 24px;
    }

    .chip {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid var(--border);
      padding: 6px 14px;
      border-radius: 3px;
      font-size: 0.85rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: background var(--transition-fast);
    }
    .chip:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: var(--red);
    }
    .chip .bullet {
      width: 6px;
      height: 6px;
      background: var(--red);
      border-radius: 50%;
    }

    /* List styling inside overview */
    .metadata-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 24px;
    }

    .metadata-item {
      display: grid;
      grid-template-columns: 180px 1fr;
      padding: 10px 14px;
      background: rgba(255, 255, 255, 0.01);
      border-left: 3px solid var(--red);
      border-radius: 0 4px 4px 0;
      font-size: 0.85rem;
    }
    .metadata-key {
      font-weight: bold;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .metadata-value {
      font-family: var(--font-mono);
      word-break: break-all;
    }

    /* Sidebar Telemetry */
    .sidebar-widget {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .module-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--border);
      border-radius: 4px;
      font-size: 0.85rem;
    }
    .module-info-left {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .module-badge {
      background: var(--red);
      color: white;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      width: 18px;
      height: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 2px;
    }
    .module-name {
      font-weight: 700;
    }
    .module-status {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: bold;
      text-transform: uppercase;
      color: var(--color-secure);
    }

    /* ═══════════════ CODE FINDINGS TAB ═══════════════ */
    .search-filter-bar {
      display: flex;
      gap: 12px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }
    .search-input {
      flex: 1;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid var(--border);
      color: var(--text-primary);
      padding: 10px 16px;
      font-size: 0.88rem;
      border-radius: 4px;
      outline: none;
      transition: border-color var(--transition-fast);
    }
    .search-input:focus {
      border-color: var(--red);
    }
    .filter-select {
      background: var(--bg-subtle);
      border: 1px solid var(--border);
      color: var(--text-primary);
      padding: 10px 16px;
      font-size: 0.88rem;
      border-radius: 4px;
      outline: none;
      cursor: pointer;
    }
    .filter-select:focus {
      border-color: var(--red);
    }

    .findings-container {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .finding-card {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--border);
      border-left: 4px solid var(--color-info);
      border-radius: 4px;
      transition: transform var(--transition-fast), border-color var(--transition-fast);
      overflow: hidden;
    }
    .finding-card:hover {
      border-color: var(--red);
    }

    .finding-card.risk-critical { border-left-color: var(--color-critical); }
    .finding-card.risk-high { border-left-color: var(--color-warning); }
    .finding-card.risk-medium { border-left-color: var(--color-warning); }
    .finding-card.risk-low { border-left-color: var(--color-secure); }
    .finding-card.risk-info { border-left-color: var(--color-info); }

    .finding-header {
      padding: 16px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      user-select: none;
      flex-wrap: wrap;
      gap: 12px;
    }

    .finding-title-box {
      display: flex;
      align-items: center;
      gap: 12px;
      flex: 1;
      min-width: 260px;
    }
    
    .indicator-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--color-info);
    }
    .finding-card.risk-critical .indicator-dot { background: var(--color-critical); box-shadow: 0 0 6px var(--color-critical); }
    .finding-card.risk-high .indicator-dot { background: var(--color-warning); }
    .finding-card.risk-medium .indicator-dot { background: var(--color-warning); }
    .finding-card.risk-low .indicator-dot { background: var(--color-secure); }

    .finding-title-text {
      font-size: 0.95rem;
      font-weight: 700;
    }

    .finding-badge-box {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .tag-badge {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      font-weight: bold;
      padding: 3px 8px;
      text-transform: uppercase;
      border-radius: 2px;
    }
    .badge-cat {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--border);
      color: var(--text-secondary);
    }
    
    .expand-arrow {
      font-size: 0.72rem;
      color: var(--text-secondary);
      transition: transform 0.25s;
    }

    .finding-card.expanded .expand-arrow {
      transform: rotate(180deg);
      color: var(--red);
    }

    .finding-body {
      display: none;
      padding: 20px;
      background: rgba(0, 0, 0, 0.2);
      border-top: 1px dashed var(--border);
    }

    .details-row {
      display: grid;
      grid-template-columns: 140px 1fr;
      gap: 12px;
      font-size: 0.85rem;
      margin-bottom: 8px;
    }

    .details-lbl {
      font-family: var(--font-mono);
      color: var(--text-secondary);
      text-transform: uppercase;
      font-weight: bold;
    }

    .details-val-code {
      font-family: var(--font-mono);
      background: rgba(211, 13, 48, 0.05);
      border: 1px solid rgba(211, 13, 48, 0.1);
      padding: 2px 6px;
      color: #ff6b8b;
      word-break: break-all;
    }

    .code-snippet-box {
      margin-top: 12px;
      background: #0d0d10;
      border: 1px solid var(--border-strong);
      padding: 14px;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: #39ffb9;
      white-space: pre-wrap;
      overflow-x: auto;
      border-radius: 3px;
      box-shadow: inset 0 0 10px rgba(0,0,0,0.8);
    }

    .empty-state {
      padding: 40px;
      text-align: center;
      border: 1px dashed var(--border);
      background: rgba(255, 255, 255, 0.01);
      border-radius: 4px;
    }

    .empty-icon {
      font-size: 2.5rem;
      margin-bottom: 12px;
      opacity: 0.5;
    }

    /* Compliance Table and Help styling */
    .compliance-card {
      background: rgba(255, 255, 255, 0.01);
      border: 1px solid var(--border);
      padding: 20px;
      border-radius: 4px;
      margin-bottom: 20px;
    }
    
    .compliance-card h3 {
      font-size: 1rem;
      margin-bottom: 10px;
      color: var(--red);
      font-family: var(--font-sans);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .compliance-rule {
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      font-size: 0.88rem;
    }
    .compliance-rule:last-child {
      border-bottom: none;
    }
    .rule-title {
      font-weight: 600;
    }
    .rule-status {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      font-weight: bold;
    }
    .status-pass { color: var(--color-secure); }
    .status-info { color: var(--color-info); }

    /* ═══════════════ FOOTER ═══════════════ */
    .footer {
      text-align: center;
      padding: 32px 0 16px;
      border-top: 1px solid var(--border);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: var(--text-muted);
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    .footer a {
      color: var(--red);
      text-decoration: none;
    }
    .footer a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>

  <div class="container">
    
    <!-- HEADER PANEL -->
    <header class="hud-panel">
      <div class="hud-corner c-tl"></div>
      <div class="hud-corner c-tr"></div>
      <div class="hud-corner c-bl"></div>
      <div class="hud-corner c-br"></div>
      
      <div class="header animate-in">
        <div class="header-left">
          <div class="logo-container">🌐</div>
          <div class="title-area">
            <h1>AI Repository <span>Scanner MVP</span></h1>
            <a class="repo-link" href="{{ result.repository }}" target="_blank" rel="noopener">
              📂 {{ result.repository }} ↗
            </a>
          </div>
        </div>
        <div class="header-right">
          <button class="theme-toggle-btn" onclick="toggleTheme()">Toggle Theme</button>
          <span class="timestamp">SCAN RUN: {{ result.scan_timestamp }}</span>
        </div>
      </div>
    </header>

    <!-- TOP SUMMARY HUD -->
    <section class="summary-grid">
      
      <!-- RADIAL DIAL CARD -->
      <div class="hud-panel dial-wrapper">
        <div class="hud-corner c-tl"></div>
        <div class="hud-corner c-tr"></div>
        <div class="hud-corner c-bl"></div>
        <div class="hud-corner c-br"></div>
        
        <div class="dial-svg-container">
          <svg class="dial-svg" viewBox="0 0 100 100">
            <circle class="dial-track" cx="50" cy="50" r="40" />
            <circle class="dial-progress" cx="50" cy="50" r="40" 
                    stroke-dasharray="251.2" 
                    stroke-dashoffset="{{ 251.2 - (result.confidence_score / 100) * 251.2 }}"
                    stroke="{% if result.confidence_score >= 90 %}#00ffcc{% elif result.confidence_score >= 70 %}#ffd200{% else %}#d30d30{% endif %}" />
          </svg>
          <div class="dial-text">
            <div class="dial-number" style="color: {% if result.confidence_score >= 90 %}#00ffcc{% elif result.confidence_score >= 70 %}#ffd200{% else %}#d30d30{% endif %};">
              {{ result.confidence_score }}%
            </div>
            <div class="dial-label">Confidence</div>
          </div>
        </div>
        
        <span class="confidence-badge {% if result.confidence_score >= 90 %}conf-high{% elif result.confidence_score >= 70 %}conf-med{% else %}conf-low{% endif %}">
          {% if result.confidence_score >= 90 %}
            Full Match
          {% elif result.confidence_score >= 70 %}
            Partial Match
          {% else %}
            Loose Footprint
          {% endif %}
        </span>
      </div>

      <!-- SUMMARY COUNTERS CARD -->
      <div class="hud-panel cards-grid">
        <div class="hud-corner c-tl"></div>
        <div class="hud-corner c-tr"></div>
        <div class="hud-corner c-bl"></div>
        <div class="hud-corner c-br"></div>

        <div class="hud-card">
          <span class="card-label">Total Findings</span>
          <span class="card-value" style="color: var(--color-info);">{{ result.findings|length }}</span>
          <span class="card-desc">AI Code Signatures</span>
        </div>

        <div class="hud-card">
          <span class="card-label">Languages</span>
          <span class="card-value" style="color: var(--color-secure);">{{ result.languages|length }}</span>
          <span class="card-desc">Source Dialects</span>
        </div>

        <div class="hud-card">
          <span class="card-label">Frameworks</span>
          <span class="card-value" style="color: var(--color-warning);">{{ result.frameworks|length }}</span>
          <span class="card-desc">AI Orchestrations</span>
        </div>

        <div class="hud-card">
          <span class="card-label">Models Detected</span>
          <span class="card-value" style="color: #ff6b8b;">{{ result.models|length }}</span>
          <span class="card-desc">Target LLMs/SLMs</span>
        </div>
      </div>
    </section>

    <!-- NAVIGATION TABS -->
    <nav class="tab-bar">
      <button class="tab-btn active" onclick="switchTab('overview')">Ecosystem Overview</button>
      <button class="tab-btn" onclick="switchTab('findings')">Code Findings ({{ result.findings|length }})</button>
      <button class="tab-btn" onclick="switchTab('compliance')">Confidence & Compliance</button>
    </nav>

    <!-- TAB: ECOSYSTEM OVERVIEW -->
    <div id="overview-tab" class="tab-content active">
      <div class="main-grid">
        
        <!-- Left Side: Breakdown lists -->
        <div class="hud-panel">
          <div class="hud-corner c-tl"></div>
          <div class="hud-corner c-tr"></div>
          <div class="hud-corner c-bl"></div>
          <div class="hud-corner c-br"></div>

          <!-- LANGUAGES -->
          <h2 class="overview-section-title">Languages Detected</h2>
          <div class="chips-container">
            {% for lang in result.languages %}
              <span class="chip"><span class="bullet"></span> {{ lang }}</span>
            {% else %}
              <span class="chip" style="color: var(--text-muted);">None Detected</span>
            {% endfor %}
          </div>

          <!-- FRAMEWORKS -->
          <h2 class="overview-section-title">AI Frameworks & Libraries</h2>
          <div class="chips-container">
            {% for fw in result.frameworks %}
              <span class="chip" style="border-color: var(--color-warning);"><span class="bullet" style="background: var(--color-warning);"></span> {{ fw }}</span>
            {% else %}
              <span class="chip" style="color: var(--text-muted);">None Declared</span>
            {% endfor %}
          </div>

          <!-- MODELS -->
          <h2 class="overview-section-title">Target Models</h2>
          <div class="chips-container">
            {% for m in result.models %}
              <span class="chip" style="border-color: #ff6b8b;"><span class="bullet" style="background: #ff6b8b;"></span> {{ m }}</span>
            {% else %}
              <span class="chip" style="color: var(--text-muted);">No Named Models</span>
            {% endfor %}
          </div>

          <!-- ARCHITECTURES -->
          <h2 class="overview-section-title">AI System Architectures</h2>
          <div class="chips-container">
            {% for c in result.components %}
              <span class="chip" style="border-color: var(--color-secure);"><span class="bullet" style="background: var(--color-secure);"></span> {{ c }}</span>
            {% else %}
              <span class="chip" style="color: var(--text-muted);">No AI Architecture Identified</span>
            {% endfor %}
          </div>
        </div>

        <!-- Right Side: Sidebar stats -->
        <div class="hud-panel sidebar-widget">
          <div class="hud-corner c-tl"></div>
          <div class="hud-corner c-tr"></div>
          <div class="hud-corner c-bl"></div>
          <div class="hud-corner c-br"></div>
          
          <h2 class="overview-section-title" style="margin-bottom: 8px;">Scan Telemetry</h2>
          
          <div class="module-item">
            <div class="module-info-left">
              <span class="module-badge">02</span>
              <span class="module-name">File Scanner</span>
            </div>
            <span class="module-status">ACTIVE</span>
          </div>

          <div class="module-item">
            <div class="module-info-left">
              <span class="module-badge">04</span>
              <span class="module-name">Package Scanner</span>
            </div>
            <span class="module-status">ACTIVE</span>
          </div>

          <div class="module-item">
            <div class="module-info-left">
              <span class="module-badge">05</span>
              <span class="module-name">Agent Scanner</span>
            </div>
            <span class="module-status">ACTIVE</span>
          </div>

          <div class="module-item">
            <div class="module-info-left">
              <span class="module-badge">08</span>
              <span class="module-name">MCP Scanner</span>
            </div>
            <span class="module-status">ACTIVE</span>
          </div>
        </div>

      </div>
    </div>

    <!-- TAB: CODE FINDINGS -->
    <div id="findings-tab" class="tab-content">
      <div class="hud-panel">
        <div class="hud-corner c-tl"></div>
        <div class="hud-corner c-tr"></div>
        <div class="hud-corner c-bl"></div>
        <div class="hud-corner c-br"></div>

        <!-- Filter bar -->
        <div class="search-filter-bar">
          <input type="text" id="searchInput" class="search-input" placeholder="Search findings by file, pattern, snippet..." oninput="filterFindings()" />
          <select id="categoryFilter" class="filter-select" onchange="filterFindings()">
            <option value="ALL">All Categories</option>
            {% for c in result.components %}
              <option value="{{ c }}">{{ c }}</option>
            {% endfor %}
          </select>
        </div>

        <!-- Accordion list -->
        <div class="findings-container" id="findingsContainer">
          {% for f in result.findings %}
            <div class="finding-card risk-info" data-category="{{ f.category }}" data-text="{{ f.file.lower() }} {{ f.category.lower() }} {{ f.matched_pattern.lower() }} {{ f.snippet.lower() }}">
              <div class="finding-header" onclick="toggleCard(this)">
                <div class="finding-title-box">
                  <div class="indicator-dot"></div>
                  <div class="finding-title-text">{{ f.file }} (Line {{ f.line }})</div>
                </div>
                <div class="finding-badge-box">
                  <span class="tag-badge badge-cat">{{ f.category }}</span>
                  <span class="expand-arrow">▼</span>
                </div>
              </div>
              <div class="finding-body">
                <div class="details-row">
                  <span class="details-lbl">File Reference</span>
                  <span class="details-val"><span class="details-val-source">{{ f.file }}:{{ f.line }}</span></span>
                </div>
                <div class="details-row">
                  <span class="details-lbl">Matched Pattern</span>
                  <span class="details-val"><span class="details-val-code">{{ f.matched_pattern }}</span></span>
                </div>
                <div class="code-snippet-box">{{ f.snippet }}</div>
              </div>
            </div>
          {% else %}
            <div class="empty-state">
              <div class="empty-icon">🛡️</div>
              <div class="empty-state-title">No Code Signatures Found</div>
              <div class="empty-state-text">No AI frameworks, models, or components were detected in this repository's source code files.</div>
            </div>
          {% endfor %}
        </div>

      </div>
    </div>

    <!-- TAB: CONFIDENCE & COMPLIANCE -->
    <div id="compliance-tab" class="tab-content">
      <div class="hud-panel">
        <div class="hud-corner c-tl"></div>
        <div class="hud-corner c-tr"></div>
        <div class="hud-corner c-bl ="></div>
        <div class="hud-corner c-br"></div>

        <div class="compliance-card">
          <h3>Confidence Scoring Methodology</h3>
          <p style="font-size: 0.9rem; margin-bottom: 12px; color: var(--text-secondary);">
            The confidence score evaluates the certainty of the repository's AI footprint based on standard scoring heuristics:
          </p>
          <div class="compliance-rule">
            <span class="rule-title">Dependency Declarations Only (requirements.txt / package.json)</span>
            <span class="rule-status status-info">30% Score</span>
          </div>
          <div class="compliance-rule">
            <span class="rule-title">Source Code Instantiations & Import Usages Detected</span>
            <span class="rule-status status-info">50% Score</span>
          </div>
          <div class="compliance-rule">
            <span class="rule-title">Ecosystem Dependencies + Source Code Pattern Matches</span>
            <span class="rule-status status-info">70% Score</span>
          </div>
          <div class="compliance-rule">
            <span class="rule-title">Ecosystem + Code Usage + Configuration Elements (e.g., .env / MCP configuration files)</span>
            <span class="rule-status status-pass">95% Score</span>
          </div>
        </div>

        <div class="compliance-card">
          <h3>Compliance Policy Evaluation</h3>
          <div class="compliance-rule">
            <span class="rule-title">Public Repository Vulnerability Disclosure Policy</span>
            <span class="rule-status status-pass">Pass</span>
          </div>
          <div class="compliance-rule">
            <span class="rule-title">AI Credentials & Secrets Masking Integrity Check</span>
            <span class="rule-status status-pass">Verified</span>
          </div>
          <div class="compliance-rule">
            <span class="rule-title">Open Source Licensing Compliance Audit</span>
            <span class="rule-status status-pass">Active</span>
          </div>
        </div>

      </div>
    </div>

    <!-- FOOTER -->
    <footer class="footer">
      Powered by <a href="https://talakunchi.com" target="_blank" rel="noopener">Talakunchi Networks Pvt Ltd</a> · AI Discovery Scanner v{{ version }}
    </footer>

  </div>

  <script>
    // Theme Management
    const body = document.body;
    
    function loadTheme() {
      const savedTheme = localStorage.getItem('scanner-theme') || 'dark';
      if (savedTheme === 'light') {
        body.classList.add('light-theme');
      } else {
        body.classList.remove('light-theme');
      }
    }
    
    function toggleTheme() {
      if (body.classList.contains('light-theme')) {
        body.classList.remove('light-theme');
        localStorage.setItem('scanner-theme', 'dark');
      } else {
        body.classList.add('light-theme');
        localStorage.setItem('scanner-theme', 'light');
      }
    }

    document.addEventListener('DOMContentLoaded', loadTheme);

    // Tab Switcher
    function switchTab(tabId) {
      const buttons = document.querySelectorAll('.tab-btn');
      const contents = document.querySelectorAll('.tab-content');
      
      buttons.forEach(btn => btn.classList.remove('active'));
      contents.forEach(content => content.classList.remove('active'));
      
      const targetBtn = Array.from(buttons).find(btn => btn.textContent.toLowerCase().includes(tabId));
      if (targetBtn) targetBtn.classList.add('active');
      
      const targetContent = document.getElementById(`${tabId}-tab`);
      if (targetContent) targetContent.classList.add('active');
    }

    // Collapsible Cards
    function toggleCard(header) {
      const card = header.parentElement;
      card.classList.toggle('expanded');
      
      const body = card.querySelector('.finding-body');
      if (card.classList.contains('expanded')) {
        body.style.display = 'block';
      } else {
        body.style.display = 'none';
      }
    }

    // Search and Category Filter
    function filterFindings() {
      const searchText = document.getElementById('searchInput').value.toLowerCase().trim();
      const filterCategory = document.getElementById('categoryFilter').value;
      const cards = document.querySelectorAll('.finding-card');
      
      cards.forEach(card => {
        const cardCategory = card.getAttribute('data-category');
        const cardText = card.getAttribute('data-text');
        
        const categoryMatch = (filterCategory === 'ALL' || cardCategory === filterCategory);
        const textMatch = (!searchText || cardText.includes(searchText));
        
        if (categoryMatch && textMatch) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    }
  </script>
</body>
</html>
