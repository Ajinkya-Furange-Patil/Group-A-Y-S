<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI Discovery Scanner — Dashboard</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&display=swap');

    :root {
      /* TALAKUNCHI RED-WHITE LIGHT THEME (Default) */
      --bg: #f2f6f7;
      --surface: #ffffff;
      --glass: rgba(255, 255, 255, 0.7);
      --glass-border: rgba(236, 44, 51, 0.12);
      --border-accent: rgba(236, 44, 51, 0.22);
      --text-primary: #222222;
      --text-secondary: #656a7c;
      --text-muted: #9da3b4;
      
      --accent-red: #ec2c33;
      --accent-burgundy: #730605;
      --accent-orange: #ec691f;
      
      --status-success: #15803d;
      --status-warning: #ec691f;
      --status-danger: #ec2c33;
      --status-info: #656a7c;

      --tag-bg-category: rgba(236, 44, 51, 0.06);
      --tag-fg-category: #9a2423;
      --tag-border-category: rgba(236, 44, 51, 0.15);

      --card-bg: rgba(255, 255, 255, 0.6);
      --card-border: rgba(236, 44, 51, 0.12);
      
      --input-bg: rgba(255, 255, 255, 0.85);
      --input-border: rgba(236, 44, 51, 0.18);

      --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
      --font-sans: 'Lato', system-ui, sans-serif;
      --font-title: 'DM Sans', sans-serif;
      --radius-lg: 16px;
      --radius-md: 10px;
      --radius-sm: 6px;
      --shadow-lg: 0 10px 40px -10px rgba(115, 6, 5, 0.05), 0 2px 10px rgba(0, 0, 0, 0.01);
      --blur: blur(20px) saturate(180%);
      
      --glow-color: rgba(236, 44, 51, 0.04);
      --glow-color-2: rgba(236, 105, 31, 0.03);
      --bg-gradient: radial-gradient(circle at 10% 20%, var(--glow-color) 0%, transparent 40%),
                     radial-gradient(circle at 90% 80%, var(--glow-color-2) 0%, transparent 45%),
                     linear-gradient(135deg, #f2f6f7 0%, #ffffff 100%);
    }

    /* Dark Theme Settings */
    body.dark-theme {
      /* CHARCOAL/CRIMSON DARK THEME */
      --bg: #121010;
      --surface: #1c1818;
      --glass: rgba(28, 24, 24, 0.7);
      --glass-border: rgba(255, 255, 255, 0.08);
      --border-accent: rgba(236, 44, 51, 0.28);
      --text-primary: #faf8f8;
      --text-secondary: #d6cfcf;
      --text-muted: #968e8e;
      
      --accent-red: #ff4a51;
      --accent-burgundy: #a82b2a;
      --accent-orange: #ff8542;
      
      --status-success: #10b981;
      --status-warning: #ff8542;
      --status-danger: #ff4a51;
      --status-info: #968e8e;

      --tag-bg-category: rgba(255, 74, 81, 0.12);
      --tag-fg-category: #ff8287;
      --tag-border-category: rgba(255, 74, 81, 0.25);

      --card-bg: rgba(255, 255, 255, 0.03);
      --card-border: rgba(255, 255, 255, 0.08);

      --input-bg: rgba(0, 0, 0, 0.35);
      --input-border: rgba(255, 255, 255, 0.1);

      --shadow-lg: 0 12px 40px -10px rgba(0, 0, 0, 0.65);
      --glow-color: rgba(236, 44, 51, 0.08);
      --glow-color-2: rgba(236, 105, 31, 0.05);
      --bg-gradient: radial-gradient(circle at 10% 20%, var(--glow-color) 0%, transparent 40%),
                     radial-gradient(circle at 90% 80%, var(--glow-color-2) 0%, transparent 45%),
                     linear-gradient(135deg, #121010 0%, #1c1818 100%);
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-title);
    }

    body {
      font-family: var(--font-sans);
      background-color: var(--bg);
      background-image: var(--bg-gradient);
      color: var(--text-primary);
      padding: 24px;
      min-height: 100vh;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      transition: background-color 0.3s, color 0.3s;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    /* ═══════════════ GLASS CONTAINER ═══════════════ */
    .glass-panel {
      background: var(--glass);
      backdrop-filter: var(--blur);
      -webkit-backdrop-filter: var(--blur);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg);
      padding: 24px;
      position: relative;
      overflow: hidden;
      transition: background-color 0.3s, border-color 0.3s, box-shadow 0.3s;
    }

    /* Scanline animation */
    .scanline {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent 0%, rgba(236, 44, 51, 0.35) 50%, transparent 100%);
      pointer-events: none;
      animation: scanAnim 8s ease-in-out infinite;
      z-index: 9999;
    }
    @keyframes scanAnim {
      from { transform: translateY(-10vh); opacity: 0.3; }
      50% { opacity: 0.6; }
      to { transform: translateY(110vh); opacity: 0; }
    }

    /* ═══════════════ HEADER ═══════════════ */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px;
      padding-top: 28px;
    }
    .header::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--accent-red), var(--accent-burgundy), var(--accent-orange));
    }
    .header-logo {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .header-logo .icon {
      font-size: 2rem;
      background: rgba(236, 44, 51, 0.08);
      border: 1px solid var(--border-accent);
      width: 50px;
      height: 50px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--radius-md);
      box-shadow: 0 0 15px rgba(236, 44, 51, 0.12);
    }
    .header-title h1 {
      font-size: 1.5rem;
      font-weight: 800;
      letter-spacing: -0.025em;
    }
    .header-title p {
      font-size: 0.875rem;
      color: var(--text-secondary);
      font-family: var(--font-mono);
    }
    .header-actions {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .btn-toggle {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      color: var(--text-primary);
      padding: 8px 12px;
      border-radius: var(--radius-md);
      cursor: pointer;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: all 0.2s;
    }
    .btn-toggle:hover {
      background: rgba(255, 255, 255, 0.5);
      border-color: var(--border-accent);
    }
    body.dark-theme .btn-toggle:hover {
      background: rgba(255, 255, 255, 0.06);
    }
    .scan-badge {
      display: inline-flex;
      align-items: center;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
      font-family: var(--font-mono);
      background: rgba(236, 44, 51, 0.08);
      color: var(--accent-red);
      border: 1px solid var(--border-accent);
    }

    /* ═══════════════ METRICS SUMMARY GRID ═══════════════ */
    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
    }
    .metric-card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: var(--radius-md);
      padding: 18px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    }
    .metric-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 30px -10px rgba(236, 44, 51, 0.15);
      border-color: var(--border-accent);
    }
    .metric-header {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      font-weight: 600;
      margin-bottom: 8px;
    }
    .metric-value {
      font-size: 2rem;
      font-weight: 700;
      font-family: var(--font-mono);
      color: var(--text-primary);
    }
    .metric-footer {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-top: 8px;
    }
    .metric-card.critical-risk {
      border-left: 4px solid var(--status-danger);
      background: rgba(239, 68, 68, 0.03);
    }
    .metric-card.critical-risk .metric-value {
      color: var(--status-danger);
    }

    /* ═══════════════ METADATA & GRID ═══════════════ */
    .dashboard-layout {
      display: grid;
      grid-template-columns: 3fr 1fr;
      gap: 24px;
    }
    @media (max-width: 968px) {
      .dashboard-layout {
        grid-template-columns: 1fr;
      }
    }
    
    .meta-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
    }
    .meta-item {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .meta-label {
      font-size: 0.75rem;
      color: var(--text-muted);
      text-transform: uppercase;
      font-weight: 600;
    }
    .meta-val {
      font-size: 0.95rem;
      font-family: var(--font-mono);
      word-break: break-all;
    }

    /* ═══════════════ MODULE OVERVIEW ═══════════════ */
    .modules-section h2, .findings-section h2 {
      font-size: 1.15rem;
      font-weight: 700;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .modules-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .module-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 16px;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: var(--radius-md);
      transition: all 0.2s;
    }
    .module-row:hover {
      background: rgba(255, 255, 255, 0.55);
      border-color: var(--border-accent);
    }
    body.dark-theme .module-row:hover {
      background: rgba(255, 255, 255, 0.04);
    }
    .module-info {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .module-num {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--text-muted);
      background: rgba(0, 0, 0, 0.05);
      padding: 2px 6px;
      border-radius: var(--radius-sm);
    }
    body.dark-theme .module-num {
      background: rgba(255, 255, 255, 0.05);
    }
    .module-name {
      font-size: 0.9rem;
      font-weight: 600;
    }
    .module-meta {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .module-duration {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--text-muted);
    }
    .status-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 3px 8px;
      border-radius: 4px;
      font-size: 0.7rem;
      font-family: var(--font-mono);
      font-weight: 600;
      text-transform: uppercase;
    }
    .status-success {
      background: rgba(21, 128, 61, 0.08);
      color: var(--status-success);
      border: 1px solid rgba(21, 128, 61, 0.15);
    }
    body.dark-theme .status-success {
      background: rgba(16, 185, 129, 0.1);
      color: var(--status-success);
      border: 1px solid rgba(16, 185, 129, 0.2);
    }
    .status-error {
      background: rgba(185, 28, 28, 0.08);
      color: var(--status-danger);
      border: 1px solid rgba(185, 28, 28, 0.15);
    }
    body.dark-theme .status-error {
      background: rgba(239, 108, 108, 0.1);
      color: var(--status-danger);
      border: 1px solid rgba(239, 108, 108, 0.2);
    }
    .status-pending {
      background: rgba(120, 113, 108, 0.08);
      color: var(--text-muted);
      border: 1px solid rgba(120, 113, 108, 0.15);
    }
    body.dark-theme .status-pending {
      background: rgba(107, 114, 128, 0.1);
      color: var(--text-muted);
      border: 1px solid rgba(107, 114, 128, 0.2);
    }
    .findings-count-badge {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      font-weight: 600;
      background: rgba(236, 44, 51, 0.08);
      color: var(--accent-red);
      border: 1px solid var(--border-accent);
      padding: 2px 8px;
      border-radius: 12px;
    }

    /* ═══════════════ FINDINGS LAYOUT ═══════════════ */
    .filter-bar {
      display: flex;
      gap: 12px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }
    .search-input {
      flex: 1;
      min-width: 200px;
      background: var(--input-bg);
      border: 1px solid var(--input-border);
      padding: 10px 16px;
      border-radius: var(--radius-md);
      color: var(--text-primary);
      font-family: var(--font-sans);
      font-size: 0.875rem;
      transition: all 0.2s;
    }
    .search-input:focus {
      outline: none;
      border-color: var(--accent-red);
      box-shadow: 0 0 10px rgba(236, 44, 51, 0.15);
    }
    .filter-select {
      background: var(--input-bg);
      border: 1px solid var(--input-border);
      padding: 10px 16px;
      border-radius: var(--radius-md);
      color: var(--text-primary);
      font-size: 0.875rem;
      cursor: pointer;
      min-width: 150px;
      transition: all 0.2s;
    }
    .filter-select:focus {
      outline: none;
      border-color: var(--accent-red);
    }
    .filter-select option {
      background-color: var(--surface);
      color: var(--text-primary);
    }

    .findings-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .finding-card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: var(--radius-md);
      overflow: hidden;
      transition: all 0.2s;
    }
    .finding-card:hover {
      border-color: var(--border-accent);
      background: rgba(255, 255, 255, 0.55);
    }
    body.dark-theme .finding-card:hover {
      background: rgba(255, 255, 255, 0.04);
    }
    .finding-header {
      padding: 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
      cursor: pointer;
    }
    .finding-title-section {
      display: flex;
      align-items: center;
      gap: 12px;
      flex: 1;
      min-width: 250px;
    }
    .finding-risk-indicator {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .risk-critical { background-color: var(--accent-burgundy); }
    .risk-high { background-color: var(--accent-red); }
    .risk-medium { background-color: var(--accent-orange); }
    .risk-low { background-color: var(--status-info); }
    .risk-info { background-color: var(--text-muted); }

    .finding-title {
      font-size: 0.95rem;
      font-weight: 600;
    }
    .finding-meta {
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
    }
    .tag {
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 0.7rem;
      font-family: var(--font-mono);
      font-weight: 600;
    }
    .tag-category {
      background: var(--tag-bg-category);
      color: var(--tag-fg-category);
      border: 1px solid var(--tag-border-category);
    }
    .tag-risk-critical {
      background: rgba(115, 6, 5, 0.08);
      color: #730605;
      border: 1px solid rgba(115, 6, 5, 0.15);
    }
    body.dark-theme .tag-risk-critical {
      background: rgba(168, 43, 42, 0.15);
      color: #ff8287;
      border: 1px solid rgba(168, 43, 42, 0.3);
    }
    .tag-risk-high {
      background: rgba(236, 44, 51, 0.08);
      color: #ec2c33;
      border: 1px solid rgba(236, 44, 51, 0.15);
    }
    body.dark-theme .tag-risk-high {
      background: rgba(255, 74, 81, 0.15);
      color: #ff8287;
      border: 1px solid rgba(255, 74, 81, 0.3);
    }
    .tag-risk-medium {
      background: rgba(236, 105, 31, 0.08);
      color: #ec691f;
      border: 1px solid rgba(236, 105, 31, 0.15);
    }
    body.dark-theme .tag-risk-medium {
      background: rgba(255, 133, 66, 0.15);
      color: #ffac7d;
      border: 1px solid rgba(255, 133, 66, 0.3);
    }
    .tag-risk-low {
      background: rgba(101, 106, 124, 0.08);
      color: #656a7c;
      border: 1px solid rgba(101, 106, 124, 0.15);
    }
    body.dark-theme .tag-risk-low {
      background: rgba(150, 142, 142, 0.15);
      color: #d6cfcf;
      border: 1px solid rgba(150, 142, 142, 0.3);
    }
    .tag-risk-info {
      background: rgba(157, 163, 180, 0.08);
      color: #7c8397;
      border: 1px solid rgba(157, 163, 180, 0.15);
    }
    body.dark-theme .tag-risk-info {
      background: rgba(150, 142, 142, 0.1);
      color: #968e8e;
      border: 1px solid rgba(150, 142, 142, 0.2);
    }

    .expand-icon {
      font-size: 0.8rem;
      color: var(--text-muted);
      transition: transform 0.2s;
    }
    .finding-card.open .expand-icon {
      transform: rotate(180deg);
    }

    .finding-body {
      display: none;
      padding: 16px;
      background: rgba(0, 0, 0, 0.03);
      border-top: 1px solid var(--glass-border);
    }
    body.dark-theme .finding-body {
      background: rgba(0, 0, 0, 0.25);
    }
    .finding-card.open .finding-body {
      display: block;
    }

    .finding-details-grid {
      display: grid;
      grid-template-columns: 120px 1fr;
      gap: 12px;
      font-size: 0.85rem;
    }
    .fd-label {
      color: var(--text-secondary);
      font-weight: 600;
    }
    .fd-value {
      word-break: break-all;
    }
    .fd-code {
      background: rgba(0, 0, 0, 0.04);
      padding: 12px;
      border-radius: var(--radius-sm);
      font-family: var(--font-mono);
      font-size: 0.8rem;
      white-space: pre-wrap;
      overflow-x: auto;
      border: 1px solid var(--glass-border);
      color: #047857;
      grid-column: 1 / -1;
      margin-top: 8px;
    }
    body.dark-theme .fd-code {
      background: rgba(0, 0, 0, 0.45);
      color: #34d399;
    }

    .no-findings {
      text-align: center;
      padding: 40px;
      color: var(--text-muted);
      font-size: 0.95rem;
    }

    /* ═══════════════ FOOTER ═══════════════ */
    .footer {
      text-align: center;
      padding: 24px 0;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    /* ═══════════════ SCROLLBAR ═══════════════ */
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }
    ::-webkit-scrollbar-track {
      background: var(--bg);
    }
    ::-webkit-scrollbar-thumb {
      background: var(--glass-border);
      border-radius: 4px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: var(--border-accent);
    }
  </style>
</head>
<body>
  <div class="scanline"></div>

  <div class="container">
    
    <!-- ═══ HEADER PANEL ═══ -->
    <header class="glass-panel header">
      <div class="header-logo">
        <div class="icon">🔍</div>
        <div class="header-title">
          <h1>AI Discovery Scanner</h1>
          <p>// Target Host: {{ result.hostname }}</p>
        </div>
      </div>
      
      <div class="header-actions">
        <span class="scan-badge">Scan ID: {{ result.scan_id[:8] }}</span>
        <button class="btn-toggle" id="theme-toggle">
          <span id="theme-icon">☀️</span> <span id="theme-text">LIGHT</span>
        </button>
      </div>
    </header>

    <!-- ═══ METRICS SUMMARY ═══ -->
    <div class="metrics-grid">
      <div class="metric-card">
        <span class="metric-header">Discovered Artifacts</span>
        <span class="metric-value">{{ result.summary.total_findings }}</span>
        <span class="metric-footer">Total items detected</span>
      </div>
      
      <div class="metric-card critical-risk">
        <span class="metric-header">Security Risk Score</span>
        <span class="metric-value">{{ result.summary.overall_risk_score }}</span>
        <span class="metric-footer">Out of 100 max</span>
      </div>

      <div class="metric-card">
        <span class="metric-header">Execution Time</span>
        <span class="metric-value">{{ "%.2f"|format(result.total_duration_sec) }}s</span>
        <span class="metric-footer">Wall-clock duration</span>
      </div>

      <div class="metric-card">
        <span class="metric-header">Scanner Status</span>
        <span class="metric-value">{{ result.summary.modules_succeeded }}/{{ result.summary.modules_run }}</span>
        <span class="metric-footer">Active modules OK</span>
      </div>
    </div>

    <!-- ═══ LAYOUT: HOST INFO & MODULES ═══ -->
    <div class="dashboard-layout">
      
      <!-- MAIN: DISCOVERED FINDINGS -->
      <section class="glass-panel findings-section">
        <h2><span>🛡️</span> Discovered AI Findings</h2>
        
        <!-- Filter Controls -->
        <div class="filter-bar">
          <input type="text" id="search-box" class="search-input" placeholder="Search by name, source or description..." />
          
          <select id="filter-category" class="filter-select">
            <option value="all">All Categories</option>
            {% for cat, count in result.summary.findings_by_category.items() %}
            <option value="{{ cat }}">{{ cat }} ({{ count }})</option>
            {% endfor %}
          </select>
          
          <select id="filter-risk" class="filter-select">
            <option value="all">All Risk Levels</option>
            {% for risk, count in result.summary.findings_by_risk.items() %}
            <option value="{{ risk }}">{{ risk|upper }} ({{ count }})</option>
            {% endfor %}
          </select>
        </div>

        <!-- Findings List -->
        <div class="findings-list" id="findings-list">
          {% if result.findings %}
            {% for finding in result.findings %}
            <div class="finding-card" 
                 data-category="{{ finding.category }}" 
                 data-risk="{{ finding.risk_level }}">
              
              <div class="finding-header" onclick="toggleFinding(this)">
                <div class="finding-title-section">
                  <div class="finding-risk-indicator risk-{{ finding.risk_level }}"></div>
                  <span class="finding-title">{{ finding.title }}</span>
                </div>
                <div class="finding-meta">
                  <span class="tag tag-category">{{ finding.category }}</span>
                  <span class="tag tag-risk-{{ finding.risk_level }}">{{ finding.risk_level|upper }}</span>
                  <span class="expand-icon">▼</span>
                </div>
              </div>

              <div class="finding-body">
                <div class="finding-details-grid">
                  <span class="fd-label">Description</span>
                  <span class="fd-value">{{ finding.description }}</span>

                  <span class="fd-label">Source location</span>
                  <span class="fd-value" style="font-family: var(--font-mono); font-size: 0.8rem;">{{ finding.source }}</span>

                  <span class="fd-label">Confidence</span>
                  <span class="fd-value">{{ "%.0f"|format(finding.confidence * 100) }}%</span>

                  <span class="fd-label">Detection time</span>
                  <span class="fd-value">{{ finding.timestamp }}</span>
                  
                  {% if finding.details %}
                  <span class="fd-label">Metadata</span>
                  <pre class="fd-code">{{ finding.details|tojson(indent=2) }}</pre>
                  {% endif %}
                </div>
              </div>
            </div>
            {% endfor %}
          {% else %}
            <div class="no-findings">
              No AI artifacts discovered on this host.
            </div>
          {% endif %}
        </div>
      </section>

      <!-- SIDEBAR: SYSTEM INFO & RUN OVERVIEW -->
      <div style="display: flex; flex-direction: column; gap: 24px;">
        
        <!-- Host Details Panel -->
        <section class="glass-panel">
          <h2><span>🖥️</span> Host Metadata</h2>
          <div class="meta-list" style="grid-template-columns: 1fr;">
            <div class="meta-item">
              <span class="meta-label">Hostname</span>
              <span class="meta-val">{{ result.hostname }}</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">Operating System</span>
              <span class="meta-val">{{ result.os_info }}</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">Scan Initiated</span>
              <span class="meta-val" style="font-size: 0.8rem;">{{ result.scan_timestamp }}</span>
            </div>
          </div>
        </section>

        <!-- Module Progress/Status -->
        <section class="glass-panel modules-section">
          <h2><span>⚡</span> Scanners Run</h2>
          <div class="modules-list">
            {% for module in result.modules %}
            <div class="module-row">
              <div class="module-info">
                <span class="module-num">{{ "%02d"|format(module.module_number) }}</span>
                <span class="module-name">{{ module.name }}</span>
              </div>
              <div class="module-meta">
                <span class="module-duration">{{ "%.3f"|format(module.duration_sec) }}s</span>
                <span class="status-badge status-{{ module.status }}">{{ module.status }}</span>
                {% if module.findings_count > 0 %}
                <span class="findings-count-badge">{{ module.findings_count }}</span>
                {% endif %}
              </div>
            </div>
            {% endfor %}
          </div>
        </section>
      </div>

    </div>

    <!-- ═══ FOOTER ═══ -->
    <footer class="footer">
      // Generated by AI Discovery Scanner v1.0.0 — Group-A-Y-S
    </footer>
  </div>

  <script>
    // Theme Toggle Logic
    const body = document.body;
    const themeToggle = document.getElementById('theme-toggle');
    const themeIcon = document.getElementById('theme-icon');
    const themeText = document.getElementById('theme-text');

    // Check saved theme
    if (localStorage.getItem('theme') === 'dark') {
      body.classList.add('dark-theme');
      themeIcon.textContent = '☀️';
      themeText.textContent = 'LIGHT';
    } else {
      body.classList.remove('dark-theme');
      themeIcon.textContent = '🌙';
      themeText.textContent = 'DARK';
    }

    themeToggle.addEventListener('click', () => {
      body.classList.toggle('dark-theme');
      const isDark = body.classList.contains('dark-theme');
      themeIcon.textContent = isDark ? '☀️' : '🌙';
      themeText.textContent = isDark ? 'LIGHT' : 'DARK';
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });

    // Expanding Finding Cards
    function toggleFinding(header) {
      const card = header.closest('.finding-card');
      card.classList.toggle('open');
    }

    // Dynamic Client-Side Filtering
    const searchBox = document.getElementById('search-box');
    const categorySelect = document.getElementById('filter-category');
    const riskSelect = document.getElementById('filter-risk');
    const findingCards = document.querySelectorAll('.finding-card');

    function applyFilters() {
      const query = searchBox.value.toLowerCase().trim();
      const category = categorySelect.value;
      const risk = riskSelect.value;

      let visibleCount = 0;

      findingCards.forEach(card => {
        const cardCategory = card.getAttribute('data-category');
        const cardRisk = card.getAttribute('data-risk');
        
        // Text search across Title, Description and Source
        const title = card.querySelector('.finding-title').textContent.toLowerCase();
        const bodyText = card.querySelector('.finding-body') ? card.querySelector('.finding-body').textContent.toLowerCase() : '';
        const matchesSearch = title.includes(query) || bodyText.includes(query);

        const matchesCategory = (category === 'all' || cardCategory === category);
        const matchesRisk = (risk === 'all' || cardRisk === risk);

        if (matchesSearch && matchesCategory && matchesRisk) {
          card.style.display = 'block';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      // Handle "No results found" dynamic banner if needed
      const listContainer = document.getElementById('findings-list');
      let noResultsBanner = document.getElementById('no-results-banner');
      
      if (visibleCount === 0) {
        if (!noResultsBanner) {
          noResultsBanner = document.createElement('div');
          noResultsBanner.id = 'no-results-banner';
          noResultsBanner.className = 'no-findings';
          noResultsBanner.textContent = 'No findings match your search/filter criteria.';
          listContainer.appendChild(noResultsBanner);
        }
      } else if (noResultsBanner) {
        noResultsBanner.remove();
      }
    }

    searchBox.addEventListener('input', applyFilters);
    categorySelect.addEventListener('change', applyFilters);
    riskSelect.addEventListener('change', applyFilters);
  </script>
</body>
</html>
