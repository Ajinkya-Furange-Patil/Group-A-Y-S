<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI Discovery Scanner — Remote Authorization Portal</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap');

    :root {
      --hud-bg: #ffffff;
      --text-muted: #475569;
      --text-main: #1e293b;
      --text-secondary: #475569;
      --hud-bg-trans: rgba(255, 255, 255, 0.9);
      --hud-panel-bg: #ffffff;
      --hud-panel-bg-hover: rgba(255, 245, 246, 0.8);
      
      --hud-red: #d30d30;
      --hud-red-glow: rgba(211, 13, 48, 0.08);
      --hud-red-dim: rgba(211, 13, 48, 0.03);
      --hud-border-dim: rgba(211, 13, 48, 0.22);

      --font-mono: 'Share Tech Mono', 'Courier New', monospace;
      --font-sans: 'Rajdhani', 'Inter', system-ui, sans-serif;
    }

    body.dark-theme {
      --hud-bg: #0b0d10;
      --text-muted: #8a99ad;
      --text-main: #f8fafc;
      --text-secondary: #8a99ad;
      --hud-bg-trans: rgba(11, 13, 16, 0.9);
      --hud-panel-bg: #12161b;
      --hud-panel-bg-hover: rgba(211, 13, 48, 0.08);
      
      --hud-red-glow: rgba(211, 13, 48, 0.15);
      --hud-red-dim: rgba(211, 13, 48, 0.05);
      --hud-border-dim: rgba(211, 13, 48, 0.35);
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: var(--font-sans);
      background-color: var(--hud-bg);
      color: var(--text-main);
      padding: 24px;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      line-height: 1.4;
      transition: background-color 0.3s;
    }

    /* Outer Container */
    .portal-container {
      width: 100%;
      max-width: 600px;
      position: relative;
    }

    /* Beveled corners decorators */
    .hud-panel {
      position: relative;
      background: var(--hud-panel-bg);
      border: 1px solid var(--hud-border-dim);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05), inset 0 0 10px rgba(0, 0, 0, 0.01);
      padding: 40px;
      transition: all 0.3s;
    }
    .hud-panel::before {
      content: '';
      position: absolute;
      top: 4px; left: 4px; right: 4px; bottom: 4px;
      border: 1px dashed rgba(211, 13, 48, 0.12);
      pointer-events: none;
    }

    .hud-corner {
      position: absolute;
      width: 12px;
      height: 12px;
      border-color: var(--hud-red);
      border-style: solid;
      pointer-events: none;
    }
    .hud-corner-tl { top: -1px; left: -1px; border-width: 2px 0 0 2px; }
    .hud-corner-tr { top: -1px; right: -1px; border-width: 2px 2px 0 0; }
    .hud-corner-bl { bottom: -1px; left: -1px; border-width: 0 0 2px 2px; }
    .hud-corner-br { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; }

    /* Header & UI Elements */
    .portal-header {
      text-align: center;
      margin-bottom: 30px;
    }
    .portal-title {
      font-size: 2.2rem;
      font-weight: 800;
      letter-spacing: 0.05em;
      color: var(--hud-red);
      text-shadow: 0 0 10px var(--hud-red-glow);
      text-transform: uppercase;
    }
    .portal-subtitle {
      font-family: var(--font-mono);
      font-size: 0.9rem;
      color: var(--text-muted);
      margin-top: 5px;
      letter-spacing: 0.08em;
    }

    .theme-toggle-container {
      position: absolute;
      top: -45px;
      right: 0;
    }
    .theme-toggle-btn {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      font-weight: 700;
      color: var(--hud-red);
      background: transparent;
      border: 1px solid var(--hud-border-dim);
      padding: 6px 14px;
      cursor: pointer;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      transition: all 0.25s;
    }
    .theme-toggle-btn:hover {
      color: var(--text-main);
      background: rgba(211, 13, 48, 0.08);
      border-color: var(--hud-red);
    }

    /* System Stats Box */
    .system-stats {
      background: var(--hud-red-dim);
      border: 1px solid var(--hud-border-dim);
      padding: 15px;
      margin-bottom: 25px;
      font-family: var(--font-mono);
      font-size: 0.9rem;
    }
    .stat-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 6px;
    }
    .stat-row:last-child {
      margin-bottom: 0;
    }
    .stat-label {
      color: var(--text-muted);
    }
    .stat-value {
      color: var(--text-main);
      font-weight: 600;
    }

    /* Scope Items List */
    .scope-box {
      margin-bottom: 25px;
    }
    .scope-title {
      font-family: var(--font-mono);
      font-size: 1rem;
      color: var(--hud-red);
      margin-bottom: 12px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .scope-list {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
    .scope-item {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.9rem;
      color: var(--text-main);
      background: var(--hud-panel-bg-hover);
      padding: 8px 12px;
      border-left: 2px solid var(--hud-red);
    }

    /* Checkboxes & Action Forms */
    .control-group {
      display: flex;
      flex-direction: column;
      gap: 15px;
      margin-bottom: 30px;
    }
    .checkbox-label {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      font-size: 0.95rem;
      cursor: pointer;
      user-select: none;
    }
    .checkbox-label input {
      margin-top: 4px;
      accent-color: var(--hud-red);
      width: 16px;
      height: 16px;
    }
    .checkbox-desc {
      color: var(--text-main);
    }
    .checkbox-help {
      font-size: 0.82rem;
      color: var(--text-muted);
      margin-top: 2px;
    }

    .btn-scan {
      display: block;
      width: 100%;
      font-family: var(--font-sans);
      font-size: 1.2rem;
      font-weight: 700;
      color: #ffffff;
      background-color: var(--hud-red);
      border: 1px solid var(--hud-red);
      padding: 14px 20px;
      cursor: pointer;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      transition: all 0.3s;
      box-shadow: 0 4px 15px rgba(211, 13, 48, 0.2);
    }
    .btn-scan:hover:not(:disabled) {
      background-color: #be0a27;
      box-shadow: 0 4px 20px rgba(211, 13, 48, 0.4);
    }
    .btn-scan:disabled {
      background-color: var(--text-muted);
      border-color: var(--text-muted);
      opacity: 0.4;
      cursor: not-allowed;
      box-shadow: none;
    }

    /* Loading / Running Scan State */
    .loading-state {
      display: none;
      text-align: center;
      padding: 20px 0;
    }
    .spinner-ring {
      display: inline-block;
      width: 60px;
      height: 60px;
      border: 3px solid rgba(211, 13, 48, 0.1);
      border-radius: 50%;
      border-top-color: var(--hud-red);
      animation: spin 1s ease-in-out infinite;
      margin-bottom: 25px;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .loading-status {
      font-family: var(--font-mono);
      font-size: 1.1rem;
      color: var(--hud-red);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }
    .loading-subtext {
      font-size: 0.9rem;
      color: var(--text-muted);
    }

    .progress-bar-container {
      width: 100%;
      height: 4px;
      background: var(--hud-red-dim);
      border: 1px solid var(--hud-border-dim);
      margin: 20px 0;
      position: relative;
      overflow: hidden;
    }
    .progress-bar-fill {
      height: 100%;
      background: var(--hud-red);
      width: 0%;
      transition: width 0.4s;
    }
    
    /* Custom Input and Select Controls */
    .control-group-hud {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 18px;
      text-align: left;
    }
    .hud-label {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      font-weight: bold;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 2px;
    }
    .hud-select, .hud-input-text, .hud-input-number {
      font-family: var(--font-sans);
      font-size: 0.92rem;
      background-color: var(--hud-panel-bg);
      border: 1px solid var(--hud-border-dim);
      color: var(--text-main);
      padding: 9px 12px;
      outline: none;
      transition: all 0.25s;
    }
    .hud-select:focus, .hud-input-text:focus, .hud-input-number:focus {
      border-color: var(--hud-red);
      box-shadow: 0 0 8px rgba(211, 13, 48, 0.25);
    }
    .hud-select option {
      background-color: var(--hud-bg);
      color: var(--text-main);
    }
    .hud-input-text::placeholder {
      color: var(--text-muted);
    }
  </style>
</head>
<body class="dark-theme">

  <div class="portal-container">
    <div class="theme-toggle-container">
      <button class="theme-toggle-btn" id="themeToggle" onclick="toggleTheme()">// THEME: DARK</button>
    </div>

    <div class="hud-panel">
      <!-- Corners decoration -->
      <div class="hud-corner hud-corner-tl"></div>
      <div class="hud-corner hud-corner-tr"></div>
      <div class="hud-corner hud-corner-bl"></div>
      <div class="hud-corner hud-corner-br"></div>

      <!-- Main Consent UI Content -->
      <div id="consentContent">
        <div class="portal-header">
          <h1 class="portal-title">System Scan Authorization</h1>
          <p class="portal-subtitle">AI Discovery Client Portal</p>
        </div>

        <div class="system-stats">
          <div class="stat-row">
            <span class="stat-label">TARGET DEVICE:</span>
            <span class="stat-value">{{ hostname }}</span>
          </div>
          <div class="stat-row">
            <span class="stat-label">OPERATING SYSTEM:</span>
            <span class="stat-value">{{ os_info }}</span>
          </div>
          <div class="stat-row">
            <span class="stat-label">LOCAL NETWORK IP:</span>
            <span class="stat-value">{{ ip_address }}</span>
          </div>
        </div>

        <div class="scope-box">
          <h2 class="scope-title">// Diagnostic Modules Scanned</h2>
          <div class="scope-list">
            <div class="scope-item">📊 System Hardware Info</div>
            <div class="scope-item">📂 Local Directory Walks</div>
            <div class="scope-item">⚙️ Running AI Processes</div>
            <div class="scope-item">📦 Package Manager (pip)</div>
            <div class="scope-item">🤖 AI Agent Code Snippets</div>
            <div class="scope-item">🔌 Local Host Listeners</div>
            <div class="scope-item">🔑 Hidden API Credentials</div>
          </div>
        </div>

        <!-- Scan Target Selector -->
        <div class="control-group-hud">
          <label class="hud-label">// Target System Region</label>
          <select id="targetRegionSelect" class="hud-select" onchange="toggleFolderInput(); validateConsent();">
            <option value="entire">Entire Host System (Full Walk)</option>
            <option value="folder">Specific Directory Path Hook</option>
          </select>
          <div id="folderInputContainer" style="display: none; margin-top: 8px;">
            <label class="hud-label">// Absolute Path Location</label>
            <input type="text" id="folderPathInput" class="hud-input-text" placeholder="e.g. C:\Users\Username\Project" style="width: 100%; box-sizing: border-box;" oninput="validateConsent();" />
          </div>
        </div>

        <!-- Scan Depth Selector -->
        <div class="control-group-hud">
          <label class="hud-label">// Filesystem Recurse Depth Limit</label>
          <select id="depthLevelSelect" class="hud-select" onchange="toggleDepthInput(); validateConsent();">
            <option value="default">Default Scan Depth (10)</option>
            <option value="faster">Faster Scan Mode (2)</option>
            <option value="custom">Custom Depth Limit...</option>
          </select>
          <div id="depthInputContainer" style="display: none; margin-top: 8px;">
            <label class="hud-label">// Max Depth Value (Integer)</label>
            <input type="number" id="customDepthInput" class="hud-input-number" min="0" max="100" value="10" style="width: 100%; box-sizing: border-box;" oninput="validateConsent();" />
          </div>
        </div>

        <div class="control-group" style="margin-top: 20px;">
          <!-- Consent Checkbox -->
          <label class="checkbox-label">
            <input type="checkbox" id="consentCheckbox" onchange="validateConsent()" />
            <div class="checkbox-desc">
              <strong>I authorize the execution of the AI Discovery Scanner</strong>
              <div class="checkbox-help">This system will inspect environment logs, filesystems, and active connections.</div>
            </div>
          </label>
        </div>

        <button class="btn-scan" id="startScanBtn" disabled onclick="triggerScan()">Authorize & Run Scan</button>
      </div>

      <!-- Loading Running Scan State -->
      <div id="loadingContent" class="loading-state">
        <div class="spinner-ring"></div>
        <div class="loading-status" id="loadingStatus">Initializing Telemetry Scan...</div>
        <div class="progress-bar-container">
          <div class="progress-bar-fill" id="progressBar"></div>
        </div>
        <div class="loading-subtext" id="loadingSubtext">Connecting to diagnostic controllers...</div>
      </div>
    </div>
  </div>

  <script>
    // Theme Management matching the main dashboard
    const body = document.body;
    const themeBtn = document.getElementById('themeToggle');

    // Load persisted theme
    const savedTheme = localStorage.getItem('theme');
    if (savedTheme === 'light') {
      body.classList.remove('dark-theme');
      themeBtn.textContent = '// THEME: LIGHT';
    } else {
      body.classList.add('dark-theme');
      themeBtn.textContent = '// THEME: DARK';
    }

    function toggleTheme() {
      if (body.classList.contains('dark-theme')) {
        body.classList.remove('dark-theme');
        themeBtn.textContent = '// THEME: LIGHT';
        localStorage.setItem('theme', 'light');
      } else {
        body.classList.add('dark-theme');
        themeBtn.textContent = '// THEME: DARK';
        localStorage.setItem('theme', 'dark');
      }
    }

    function toggleFolderInput() {
      const select = document.getElementById('targetRegionSelect');
      const container = document.getElementById('folderInputContainer');
      container.style.display = (select.value === 'folder') ? 'block' : 'none';
    }

    function toggleDepthInput() {
      const select = document.getElementById('depthLevelSelect');
      const container = document.getElementById('depthInputContainer');
      container.style.display = (select.value === 'custom') ? 'block' : 'none';
    }

    function validateConsent() {
      const isChecked = document.getElementById('consentCheckbox').checked;
      const targetRegion = document.getElementById('targetRegionSelect').value;
      let pathValid = true;
      if (targetRegion === 'folder') {
        const folderPath = document.getElementById('folderPathInput').value.trim();
        pathValid = folderPath.length > 0;
      }
      
      const depthLevel = document.getElementById('depthLevelSelect').value;
      let depthValid = true;
      if (depthLevel === 'custom') {
        const depthVal = document.getElementById('customDepthInput').value.trim();
        depthValid = depthVal.length > 0 && !isNaN(depthVal) && parseInt(depthVal) >= 0;
      }

      document.getElementById('startScanBtn').disabled = !(isChecked && pathValid && depthValid);
    }

    function triggerScan() {
      const targetRegion = document.getElementById('targetRegionSelect').value;
      const folderPath = (targetRegion === 'folder') ? document.getElementById('folderPathInput').value.trim() : '';

      const depthLevel = document.getElementById('depthLevelSelect').value;
      let depthValue = 10;
      if (depthLevel === 'faster') {
        depthValue = 2;
      } else if (depthLevel === 'custom') {
        depthValue = parseInt(document.getElementById('customDepthInput').value) || 10;
      }

      const quickScan = (depthLevel === 'faster');
      
      // Hide Consent, Show Loader
      document.getElementById('consentContent').style.display = 'none';
      document.getElementById('loadingContent').style.display = 'block';

      const progressBar = document.getElementById('progressBar');
      const loadingStatus = document.getElementById('loadingStatus');
      const loadingSubtext = document.getElementById('loadingSubtext');

      let progress = 10;
      progressBar.style.width = progress + "%";
      loadingStatus.textContent = "Launching Discovery Engines...";
      loadingSubtext.textContent = "Instantiating scanner core processes.";

      const progressInterval = setInterval(() => {
        if (progress < 90) {
          if (progress < 25) {
            progress += 5;
            progressBar.style.width = progress + "%";
            loadingStatus.textContent = "Reading Hardware Attributes...";
            loadingSubtext.textContent = "Inspecting host system configuration & CPU/RAM details.";
          } else if (progress < 45) {
            progress += 5;
            progressBar.style.width = progress + "%";
            loadingStatus.textContent = "Scanning Running Processes...";
            loadingSubtext.textContent = "Inspecting port connections & host process list.";
          } else {
            // We are scanning the filesystem, which takes the longest. Stay on this step and increment slowly.
            progress += (progress < 85) ? 1 : 0;
            progressBar.style.width = progress + "%";
            loadingStatus.textContent = "Performing System Filesystem Scan...";
            loadingSubtext.textContent = folderPath 
              ? `Walking directory: ${folderPath}` 
              : `Performing filesystem search (depth ${depthValue})...`;
          }
        }
      }, 1000);

      // Make network request to trigger the Python scan controller
      let url = `/run-scan?quick=${quickScan}&depth=${depthValue}`;
      if (folderPath) {
        url += `&folder=${encodeURIComponent(folderPath)}`;
      }

      fetch(url)
        .then(response => {
          if (!response.ok) {
            throw new Error("Scan process encountered an internal error.");
          }
          return response.json();
        })
        .then(data => {
          clearInterval(progressInterval);
          progressBar.style.width = "95%";
          loadingStatus.textContent = "Compiling Report Formats...";
          loadingSubtext.textContent = "Structuring findings and outputting visual report layouts.";
          
          setTimeout(() => {
            progressBar.style.width = "100%";
            loadingStatus.textContent = "Telemetry Scan Complete";
            loadingSubtext.textContent = "Redirecting to scan dashboard...";
            
            setTimeout(() => {
              window.location.href = "/report";
            }, 800);
          }, 1000);
        })
        .catch(err => {
          clearInterval(progressInterval);
          loadingStatus.textContent = "ERROR OCCURRED";
          loadingSubtext.textContent = err.message;
          loadingSubtext.style.color = "var(--hud-red)";
          
          setTimeout(() => {
            // Restore consent form to try again
            document.getElementById('consentContent').style.display = 'block';
            document.getElementById('loadingContent').style.display = 'none';
          }, 4000);
        });
    }
  </script>

</body>
</html>
